{
  "name": "api-testing-platform",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node src/server.js",
    "start:worker": "node src/jobs/worker.js",
    "dev": "nodemon src/server.js",
    "worker:dev": "nodemon src/jobs/worker.js",
    "test": "jest --forceExit --detectOpenHandles"
  },
"jest": {
  "testEnvironment": "node",
  "testMatch": ["**/tests/**/*.test.js"],
  "testTimeout": 15000,
  "transformIgnorePatterns": ["node_modules/(?!(is-ip|ip-regex|super-regex|function-timeout)/)"],
  "moduleNameMapper": {
    "^is-ip$": "<rootDir>/__mocks__/is-ip.js"
  }
},

  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.14.0",
    "bullmq": "^5.71.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "is-ip": "^5.0.1",
    "mongoose": "^9.3.3",
    "morgan": "^1.10.1",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
